#' Fix SomaScan analyte names
#'
#' Converts X10000_28 -> X10000.28
#' @export
fix_analyte_names <- function(x) {
sub("^X(\\d+)_(\\d+)$", "X\\1.\\2", x)
}
# require packages explicitly so installs are clear
if (!requireNamespace("dplyr", quietly = TRUE) ||
!requireNamespace("stringr", quietly = TRUE) ||
!requireNamespace("tidyr", quietly = TRUE) ||
!requireNamespace("purrr", quietly = TRUE)) {
stop("Missing required packages: dplyr, stringr, tidyr, purrr")
}
clean_token <- function(x) {
x |>
as.character() |>
stringr::str_replace_all("\u00A0", " ") |>
stringr::str_squish() |>
toupper()
}
split_multi <- function(x) {
if (is.na(x) || x == "") return(character(0))
clean_token(x) |>
stringr::str_split("[;|,/]+") |>
(\(z) z[[1]])() |>
stringr::str_squish() |>
purrr::discard(~ .x == "" | .x == "NA")
}
strip_uniprot_isoform <- function(x) stringr::str_replace(x, "-\\d+$", "")
symbol_tokens <- soma_annot[[gene_symbol_col]] |>
purrr::map(split_multi) |>
unlist() |>
unique()
