.pt_check_go_deps <- function() {
needed <- c("GO.db", "AnnotationDbi", "org.Hs.eg.db", "msigdbr", "dplyr", "stringr", "tibble")
missing <- needed[!vapply(needed, requireNamespace, logical(1), quietly = TRUE)]
if (length(missing) > 0) {
stop(
"Building GO panels requires these packages: ",
paste(missing, collapse = ", "),
".\nInstall missing packages (BiocManager for Bioconductor), or use a pre-built modules artifact.",
call. = FALSE
)
}
invisible(TRUE)
}
.pt_clean_symbol <- function(x) {
x |>
as.character() |>
stringr::str_squish() |>
toupper()
}
.pt_go_expand_offspring <- function(go_ids, ontology = c("BP", "CC", "MF")) {
ontology <- match.arg(ontology)
get_off <- function(go) {
kids <- switch(
ontology,
BP = GO.db::GOBPOFFSPRING[[go]],
CC = GO.db::GOCCOFFSPRING[[go]],
MF = GO.db::GOMFOFFSPRING[[go]]
)
unique(c(go, kids))
}
unique(unlist(lapply(go_ids, get_off), use.names = FALSE))
}
.pt_genes_from_go <- function(go_ids, keytype = c("GO", "GOALL")) {
keytype <- match.arg(keytype)
res <- AnnotationDbi::select(
org.Hs.eg.db::org.Hs.eg.db,
keys = unique(go_ids),
keytype = keytype,
columns = "SYMBOL"
)
dplyr::as_tibble(res) |>
dplyr::transmute(
SYMBOL = .pt_clean_symbol(.data$SYMBOL),
source = paste0("ORGDB_", keytype),
source_id = .data[[keytype]]
) |>
dplyr::filter(!is.na(.data$SYMBOL), .data$SYMBOL != "") |>
dplyr::distinct()
}
.pt_genes_from_reactome_msigdb <- function(include_regex, exclude_regex = NULL) {
gs <- msigdbr::msigdbr(species = "Homo sapiens", category = "C2", subcategory = "CP:REACTOME")
keep <- stringr::str_detect(gs$gs_name, stringr::regex(include_regex, ignore_case = TRUE))
if (!is.null(exclude_regex)) {
keep <- keep & !stringr::str_detect(gs$gs_name, stringr::regex(exclude_regex, ignore_case = TRUE))
}
dplyr::as_tibble(gs) |>
dplyr::filter(keep) |>
dplyr::transmute(
SYMBOL = .pt_clean_symbol(.data$gene_symbol),
source = "MSIGDB_C2_CP:REACTOME",
source_id = .data$gs_name
) |>
dplyr::filter(!is.na(.data$SYMBOL), .data$SYMBOL != "") |>
dplyr::distinct()
}
#' - `modules`: named list of SYMBOL vectors (UPS, Autophagy, Folding, ERstress, Endosome)
#' - `core_genes`: SYMBOLs present in >= 2 modules
#' - `provenance`: long table describing the source for each included gene (GO term or Reactome set)
#' - `spec`: the exact GO anchors / ontologies / regex patterns used (for justification)
#'
#' @param include_reactome Logical; if TRUE, union GO-derived genes with Reactome MSigDB genes.
#' @param go_keytype GO mapping key type: "GOALL" (default) is typically most inclusive.
#' @param spec Optional list overriding defaults for GO anchors and Reactome regexes.
#' @return A list with `modules`, `core_genes`, `provenance`, `spec`.
#' @export
build_proteostasis_modules_fixed <- function(include_reactome = TRUE,
go_keytype = c("GOALL", "GO"),
spec = NULL) {
.pt_check_go_deps()
go_keytype <- match.arg(go_keytype)
# Default spec (explicit + reproducible)
default_spec <- list(
UPS = list(
go = list(
BP = c("GO:0006511"),  # ubiquitin-dependent protein catabolic process
CC = c("GO:0000502")   # proteasome complex
),
reactome_regex = "PROTEASOM|UBIQUIT"
),
Autophagy = list(
go = list(
BP = c("GO:0006914"),  # autophagy
CC = c("GO:0005764")   # lysosome
),
reactome_regex = "AUTOPHAG|LYSOSOM"
),
Folding = list(
go = list(
BP = c("GO:0006457")   # protein folding
),
reactome_regex = "CHAPERON|HEAT_SHOCK|FOLDING"
),
ERstress = list(
go = list(
BP = c("GO:0034976")   # response to endoplasmic reticulum stress
),
reactome_regex = "ERAD|UNFOLDED|ER_STRESS"
),
Endosome = list(
go = list(
CC = c("GO:0005768")   # endosome
),
reactome_regex = "ENDOSOM|ESCRT"
)
if (!is.null(spec)) {
# simple recursive-ish merge: user overrides only provided entries
for (nm in names(spec)) default_spec[[nm]] <- modifyList(default_spec[[nm]], spec[[nm]])
}
used_spec <- default_spec
build_one <- function(module_name) {
mod <- used_spec[[module_name]]
# GO expansion (offspring)
go_terms <- character(0)
prov_go <- dplyr::tibble()
if (!is.null(mod$go)) {
for (ont in names(mod$go)) {
anchors <- mod$go[[ont]]
expanded <- .pt_go_expand_offspring(anchors, ontology = ont)
go_terms <- unique(c(go_terms, expanded))
}
if (length(go_terms) > 0) {
prov_go <- .pt_genes_from_go(go_terms, keytype = go_keytype) |>
dplyr::mutate(module = module_name, component = "GO")
}
prov_rx <- dplyr::tibble()
if (isTRUE(include_reactome) && !is.null(mod$reactome_regex)) {
prov_rx <- .pt_genes_from_reactome_msigdb(mod$reactome_regex) |>
dplyr::mutate(module = module_name, component = "REACTOME")
}
provenance <- dplyr::bind_rows(prov_go, prov_rx) |>
dplyr::distinct()
genes <- provenance |>
dplyr::pull(.data$SYMBOL) |>
unique()
list(genes = genes, provenance = provenance)
}
built <- lapply(names(used_spec), build_one)
modules <- setNames(lapply(built, `[[`, "genes"), names(used_spec))
all_genes <- unlist(modules, use.names = FALSE)
core_genes <- names(table(all_genes))[table(all_genes) >= 2]
provenance_all <- dplyr::bind_rows(lapply(built, `[[`, "provenance")) |>
dplyr::arrange(.data$module, .data$SYMBOL, .data$component, .data$source)
list(
modules = modules,
core_genes = core_genes,
provenance = provenance_all,
spec = used_spec
)
}
#' Save a fixed modules object to disk (versioned artifact)
#'
#' @param modules_obj Output of `build_proteostasis_modules_fixed()`.
#' @param path File path for the RDS (e.g., "derived/modules_fixed_v1.rds").
#' @return The path (invisibly).
#' @export
save_modules_fixed <- function(modules_obj, path) {
if (!is.list(modules_obj) || is.null(modules_obj$modules)) {
stop("modules_obj must be the output of build_proteostasis_modules_fixed().", call. = FALSE)
}
dir.create(dirname(path), recursive = TRUE, showWarnings = FALSE)
saveRDS(modules_obj, path)
invisible(path)
}
#' Load a fixed modules artifact from disk
#'
#' @param path Path to the RDS created by `save_modules_fixed()`.
#' @return The modules object.
#' @export
load_modules_fixed <- function(path) {
readRDS(path)
}
